DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=nutrition
DB_PASSWORD=nutritionpass
DB_NAME=nutrition

# Used by the local admin add-food endpoint. Change this in real local setups.
# Simple local admin protection for POST /api/admin/foods
ADMIN_TOKEN=change-me-local-admin-token

# Add your LAN frontend URL here when testing from phone/another PC.
# Comma-separated list. Example: http://localhost:3000,http://127.0.0.1:3000
FRONTEND_ORIGIN=http://localhost:3000
